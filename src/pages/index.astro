---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCarousel from "../components/ProjectCarousel.astro";
import SkillsCard from "../components/SkillsCard.astro";
import Contact from "../components/Contact.astro";

import projects from "../data/projects.js";
import skills from "../data/skills.js";
---

<BaseLayout title="Portfolio">

  <!-- Hero -->
  <section id="home">
    <div class="container">
      <img src="https://via.placeholder.com/150" class="profile" />

      <h1> Kahnishga Solaidurairaj </h1>
      <p> A Computer Science Student passionate about learning new skills and creating ✨ </p>
      <!--  <h1>Your Name</h1>
      <p>Aspiring Developer</p> -->
    </div>
  </section>

  <!-- About me (LEFT RIGHT IDEA)-->
  <section id="about">
    <div class="container">
      <h2>About Me</h2>

      <!-- Row 1 (Image LEFT, Text RIGHT) -->
      <div class="about-row">
        <div class="about-image">
          <img src="/images/uic.avif" />
        </div>

        <div class="about-text">
          <p> I’m a third-year Computer Science undergraduate at the University of Illinois at Chicago, with a minor in Mathematics and am a member of the Honors College. I live in the city and commute to campus, when the weather’s nice I like to bike, but I usually walk. At UIC, I enjoy being involved in WiCS, WiCys, WiEP, and participating in Commuter and Off-campus life events.</p>
          <p> From a young age, I have been drawn to creativity, whether through art, design, or problem-solving, which led me to programming. I love building, experimenting, and pushing my limits, and am always looking for new challenges to expand my skills. </p>
        </div>
      </div>

      <!-- Row 2 (Image RIGHT, Text LEFT) -->
      <div class="about-row reverse">
        <div class="about-image">
          <img src="/images/crochet1.avif"/>
        </div>

        <div class="about-text">
          <p> My hobbies outside of CS include crocheting and reading. I normally like to crochet smaller things like cute animals or objects. I also create tapestries, sweaters, and crochet flowers. I also like to read alot, my favorite genre is science-fiction, suspense, and thriller. I also read comics specifically webtoons. </p>
          <p> I also love to take pictures and capture my feelings + current intrests through scrapbooking, bullet journalling and just creating yearly albums.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="container">
      <h2>Projects</h2>
      <ProjectCarousel projects={projects} />
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills">
    <div class="container">
      <h2>Skills</h2>
      <SkillsCard skills={skills} />
    </container>
  </section>

  <!-- CONTACT - learning buttons utilizing icons -->
  <section id="contact">
    <div class="container">
      <Contact 
        linkedin="https://www.linkedin.com/in/kahnishga-solaidurairaj/"
        github="https://github.com/KahnishgaSolaidurairaj"
        email="ksola6@uic.edu"
      />
    </container>
  </section>

</BaseLayout>

<style>
  .container{
    margin: 3rem;
  }

  .about-row {
    display: flex;
    align-items: center;
    //justify-content: center; /* centers content horizontally */
    gap: 2rem;
    margin: 2rem auto;
    max-width: 900px;
  }

  /* Flip layout for second row */
  .about-row.reverse {
    flex-direction: row-reverse;
  }

  .about-image img {
    width: 300px;
    max-width: 300px;
    border-radius: 12px;
  }

  /* .about-text {
    flex: 1;
    background: #1e293b;
    padding: 2rem;
    border-radius: 12px;
    max-width: 500px;
  } */

  .about-text {
    flex: 1;
    background: #1e293b;
    border-radius: 12px;
    padding: 2rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .about-text p{
    color: white;
  }


  /* 📱 Responsive behavior */
  @media (max-width: 768px) {
    .about-row,
    .about-row.reverse {
      flex-direction: column;   /* stack vertically */
      text-align: center;
    }

    .about-image img {
      max-width: 100%;
    }
  }
</style>

