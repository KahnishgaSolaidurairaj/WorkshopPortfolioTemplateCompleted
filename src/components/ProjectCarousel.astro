---
import ProjectCard from "./ProjectCard.astro";
const { projects } = Astro.props;
---

<div class="carousel">
  {projects.map(project => (
    <ProjectCard {...project} />
  ))}
</div>

<style>
  .carousel {
    display: flex;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 1rem;
  }
</style>